    <string name="vampire_daily_subtitle">停放期间（无行驶）的电池损耗百分比</string>
    <string name="vampire_recent_title">近期待机时段</string>
    <string name="vampire_tips_title">优化建议</string>
    <string name="vampire_tip_sentry_title">哨兵模式</string>
    <string name="vampire_tip_sentry_desc">哨兵模式功耗约 250-300W。在安全地点停放时关闭可显著降低待机能耗。</string>
    <string name="vampire_tip_cabin_overheat_title">车内过热保护</string>
    <string name="vampire_tip_cabin_overheat_desc">该功能会运行空调以保持车内温度低于阈值。如无需此功能，可在炎热天气设为「关闭」或「仅通风」。</string>
    <string name="vampire_tip_climate_title">远程空调</string>
    <string name="vampire_tip_climate_desc">预热/预冷功耗约 3-5 kW。长时间停放时避免反复开启远程空调。</string>
    <string name="vampire_tip_updates_title">软件更新</string>
    <string name="vampire_tip_updates_desc">OTA 更新和定期检查会导致短暂唤醒。建议在插枪充电期间安排更新。</string>
    <string name="vampire_how_title">工作原理</string>
    <string name="vampire_how_desc">待机能耗通过分析充电间隔来计算。当电池电量下降但期间无行驶记录时，能量损失归因于待机功耗。估算的平均功率基于 75 kWh 电池容量。</string>
