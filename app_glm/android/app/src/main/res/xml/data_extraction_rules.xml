<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ backup / transfer.
    No cloud backup is used; all data is re-fetchable from TeslaMate.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
